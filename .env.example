# Catastro GPS MCP Server — Environment Variables

# Required: Your Catastro GPS API key (get one at https://catastrogps.es/developers)
CATASTROGPS_API_KEY=pk_live_xxx

# Optional: Backend API base URL (default: https://api.catastrogps.es)
CATASTROGPS_API_URL=https://api.catastrogps.es

# Optional: Request timeout in milliseconds (default: 10000)
CATASTROGPS_TIMEOUT=10000

# Optional: SSE server port (only for SSE transport, default: 3001)
MCP_PORT=3001
